					}
				},
				{
					"name": "Run Database Migrations",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Migration was successful\", function () {",
									"    var jsonData = pm.response.json();",
